{
    "name": "diffvision",
    "version": "0.3.2",
    "description": "Premium local-first Git diff review tool distributed as an npm CLI.",
    "type": "module",
    "private": false,
    "bin": {
        "diffvision": "dist/cli/index.js",
        "diffvision-mcp": "dist/cli/mcp.js"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md",
        "docs/screenshots"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "concurrently -k -n UI,CLI \"vite --host 127.0.0.1 --port 5173\" \"tsx src/cli/index.ts --host 127.0.0.1 --port 3210 --no-open --ui-origin http://127.0.0.1:5173\"",
        "build": "npm run build:ui && npm run build:server && npm run build:cli",
        "build:ui": "vite build",
        "build:server": "tsup src/server/index.ts --format esm --platform node --target node20 --out-dir dist/server --clean",
        "build:cli": "tsup src/cli/index.ts src/cli/mcp.ts --format esm --platform node --target node20 --out-dir dist/cli --clean",
        "lint": "eslint .",
        "test": "vitest run",
        "release": "npm run build && npm pack"
    },
    "dependencies": {
        "@fastify/static": "^8.2.0",
        "@fastify/websocket": "^11.2.0",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "boxen": "^8.0.1",
        "chalk": "^5.4.1",
        "fastify": "^5.6.1",
        "get-port": "^7.1.0",
        "lucide-react": "^0.511.0",
        "open": "^10.1.2",
        "ora": "^8.2.0",
        "prismjs": "^1.30.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.27.0",
        "@tailwindcss/vite": "^4.1.7",
        "@types/node": "^22.15.21",
        "@types/react": "^18.3.20",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^4.4.1",
        "concurrently": "^9.1.2",
        "eslint": "^9.27.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.0.0",
        "tailwindcss": "^4.1.7",
        "tsup": "^8.5.0",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.0",
        "vite": "^5.4.19",
        "vitest": "^3.1.3"
    }
}